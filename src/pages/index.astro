---
import Layout from "../layouts/Layout.astro";
import FundChart from "../components/FundChart";
---
<Layout title="MPF Logs — 基金與大市比較" description="MPF 基金數據與圖表分析">
  <section class="mb-10">
    <h1 class="mb-2 text-2xl font-bold text-foreground sm:text-3xl">
      強積金基金與大市指數比較
    </h1>
    <p class="text-muted-foreground">
      收集 MPF 基金數據，方便檢視基金回報。
    </p>
  </section>

  <section class="rounded-xl border border-border bg-card p-4 shadow-sm sm:p-6" aria-labelledby="chart-heading">
    <h2 id="chart-heading" class="mb-4 text-lg font-semibold text-foreground">
      本月表現最佳基金
    </h2>
    <FundChart client:visible />
  </section>
</Layout>
